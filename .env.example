# Supabase (required for the CRM app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: lead creation via webhooks and admin actions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: protect POST /api/vapi-leads (Make.com sends Authorization: Bearer <secret>)
# Leave unset only for local testing.
VAPI_LEADS_WEBHOOK_SECRET=your-long-random-secret

# Optional: return Supabase error details in API responses (also on when NODE_ENV !== production)
# VAPI_LEADS_DEBUG=true
