# Copy to .env.local and fill in values (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables)

# Supabase — project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Auth admin API (create users from the app). Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
